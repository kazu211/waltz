{
  "name": "waltz",
  "version": "1.1.0",
  "description": "Waltz - 家計簿Webアプリケーション",
  "private": true,
  "scripts": {
    "api:copy-types": "node scripts/copy-types.js api",
    "api:login": "npx clasp login",
    "api:push": "npm run api:copy-types && cd api && npx clasp push --force",
    "api:deploy": "npm run api:push && node api/scripts/deploy.js",
    "api:deployments": "cd api && npx clasp deployments",
    "api:open": "cd api && npx clasp open",
    "api:logs": "cd api && npx clasp logs",
    "app:copy-types": "node scripts/copy-types.js app",
    "app:dev": "npm run app:copy-types && cd app && npm run dev",
    "app:build": "npm run app:copy-types && cd app && npm run build",
    "app:preview": "cd app && npm run preview"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "typescript": "^5.4.0"
  }
}
