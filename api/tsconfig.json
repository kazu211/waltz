{
  "compilerOptions": {
    "lib": ["esnext"],
    "target": "ESNext",
    "module": "None",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
